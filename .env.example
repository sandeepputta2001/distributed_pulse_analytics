# PulseAnalytics — Local development environment variables
# Copy to .env and adjust values for your setup.
# Never commit .env to source control.

# ─── Infrastructure ───────────────────────────────────────────────────────────
PULSE_KAFKA_BROKERS=localhost:9092
PULSE_REDIS_ADDRS=localhost:6379
PULSE_CLICKHOUSE_HOSTS=localhost:9000
PULSE_CLICKHOUSE_USER=pulse
PULSE_CLICKHOUSE_PASSWORD=pulse
PULSE_CLICKHOUSE_DATABASE=pulse
PULSE_POSTGRES_DSN=postgres://pulse:pulse@localhost:5432/pulse?sslmode=disable
PULSE_MONGO_URI=mongodb://localhost:27017
PULSE_MONGO_DATABASE=pulse

# ─── Auth ─────────────────────────────────────────────────────────────────────
PULSE_AUTH_JWT_SECRET=change-me-to-a-long-random-secret-in-production
PULSE_AUTH_API_KEY_TTL=300s

# ─── Rate Limiting ────────────────────────────────────────────────────────────
PULSE_RATELIMIT_RPS=5000
PULSE_RATELIMIT_BURST=10000

# ─── GeoIP ────────────────────────────────────────────────────────────────────
PULSE_GEOIP_DB_PATH=/etc/geoip/GeoLite2-City.mmdb

# ─── Telemetry ────────────────────────────────────────────────────────────────
PULSE_OTEL_ENDPOINT=localhost:4317
PULSE_OTEL_SAMPLE_RATE=0.1
PULSE_SERVICE_ENVIRONMENT=development

# ─── Service Ports ────────────────────────────────────────────────────────────
# Gateway:   8080
# Query API: 8082
# Metrics:   exposed on /metrics of each service
